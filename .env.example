# Fine-grained PAT scoped to TUVOK_ORG with:
#   Org permissions: Members: read
#   Repo permissions: Metadata: read, Contents: read
TUVOK_TOKEN=

# GitHub org to enumerate members and private-repo basenames from.
TUVOK_ORG=dundermifflin

# Comma-separated, case-insensitive substrings checked against repo
# name / description / topics / README and gist description / filenames.
TUVOK_KEYWORDS=dundermifflin,paper

# Optional. Hard cap on paginated GitHub API calls per endpoint (default 50,
# i.e. up to 5000 items per listing). Raise this only if an org has more
# members/repos than the default covers.
#TUVOK_MAX_PAGES=50
